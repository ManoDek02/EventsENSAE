// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Utilisateur ───────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(STUDENT)
  permissions  String[]  @default([])
  filiere       String?
  promotion     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tickets          Ticket[]
  musicSuggestions MusicSuggestion[]
  votes            Vote[]
  waitlistEntries  WaitlistEntry[]

  // NextAuth
  accounts           Account[]
  sessions           Session[]
  verificationTokens VerificationToken[]

  escortRequests  EscortRequest[]  @relation("EscortRequests")
  escortProposals EscortProposal[] @relation("EscortProposals")
}

enum Role {
  STUDENT
  ADMIN
}

// ─── NextAuth ───────────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id      String   @id @default(cuid())
  token   String   @unique
  userId  String
  expires DateTime
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Événement ─────────────────────────────────────────────────
model Event {
  id                     String        @id @default(cuid())
  title                  String
  description            String
  category               EventCategory
  date                   DateTime
  location               String
  imageUrl               String?
  price                  Float         @default(0)
  capacity               Int
  deadline               DateTime?
  adminEmail  String?
  published              Boolean       @default(false)
  tags                   String[]
  allowsMusicSuggestions Boolean       @default(false)

  tickets          Ticket[]
  ticketTypes      TicketType[]
  musicSuggestions MusicSuggestion[]
  waitlistEntries  WaitlistEntry[]
  escortRequests  EscortRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum EventCategory {
  SORTIE_PEDAGOGIQUE
  CHAMPIONNAT
  GALA
  CONFERENCE
  AUTRE
}

// ─── Type de billet ────────────────────────────────────────────
model TicketType {
  id          String  @id @default(cuid())
  eventId     String
  name        String
  description String?
  price       Float   @default(0)
  seats       Int     @default(1)

  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tickets Ticket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Billet ────────────────────────────────────────────────────
model Ticket {
  id           String       @id @default(cuid())
  userId       String
  eventId      String
  ticketTypeId String?
  qrCode       String       @unique
  status       TicketStatus @default(PENDING)
  paymentId    String?
  paymentProofUrl  String?

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketType TicketType? @relation(fields: [ticketTypeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TicketStatus {
  PENDING
  PENDING_REVIEW
  CONFIRMED
  SCANNED
  CANCELLED
}

// ─── Liste d'attente ───────────────────────────────────────────
model WaitlistEntry {
  id      String @id @default(cuid())
  userId  String
  eventId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, eventId])
}

// ─── Musique ───────────────────────────────────────────────────
model MusicSuggestion {
  id       String        @id @default(cuid())
  title    String
  artist   String
  genre    String?
  link     String
  platform MusicPlatform
  approved Boolean       @default(false)
  eventId  String
  userId   String

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes Vote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MusicPlatform {
  YOUTUBE
  SPOTIFY
  SOUNDCLOUD
  OTHER
}

// ─── Vote ──────────────────────────────────────────────────────
model Vote {
  id                String @id @default(cuid())
  userId            String
  musicSuggestionId String

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  musicSuggestion MusicSuggestion @relation(fields: [musicSuggestionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, musicSuggestionId])
}

enum EscortRequestStatus {
  OPEN
  MATCHED
  CLOSED
}

enum EscortProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum GenderPreference {
  HOMME
  FEMME
  INDIFFERENT
}

model EscortRequest {
  id               String               @id @default(cuid())
  eventId          String
  requesterId      String
  title            String
  message          String
  photoUrl         String?
  genderPreference GenderPreference     @default(INDIFFERENT)
  status           EscortRequestStatus  @default(OPEN)
  phoneNumber      String?

  event     Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  requester User            @relation("EscortRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  proposals EscortProposal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EscortProposal {
  id         String               @id @default(cuid())
  requestId  String
  proposerId String
  message    String
  status     EscortProposalStatus @default(PENDING)
  phoneNumber String?

  request  EscortRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  proposer User          @relation("EscortProposals", fields: [proposerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([requestId, proposerId])
}

