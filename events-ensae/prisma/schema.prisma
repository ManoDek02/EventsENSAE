generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Utilisateur ───────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(STUDENT)
  filiere       String?
  promotion     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tickets       Ticket[]
  musicSuggestions MusicSuggestion[]
  votes         Vote[]
  waitlistEntries WaitlistEntry[]

  // NextAuth
  accounts Account[]
  sessions Session[]
  verificationTokens VerificationToken[]
}

enum Role {
  STUDENT
  ADMIN
}

// ─── NextAuth ───────────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expires   DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Événement ─────────────────────────────────────────────────
model Event {
  id          String      @id @default(cuid())
  title       String
  description String
  category    EventCategory
  date        DateTime
  location    String
  imageUrl    String?
  price       Float       @default(0)
  capacity    Int
  deadline    DateTime?
  published   Boolean     @default(false)
  tags        String[]
  allowsMusicSuggestions Boolean @default(false)

  tickets       Ticket[]
  musicSuggestions MusicSuggestion[]
  waitlistEntries WaitlistEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum EventCategory {
  SORTIE_PEDAGOGIQUE
  CHAMPIONNAT
  GALA
  CONFERENCE
  AUTRE
}

// ─── Billet ────────────────────────────────────────────────────
model Ticket {
  id        String       @id @default(cuid())
  userId    String
  eventId   String
  qrCode    String       @unique
  status    TicketStatus @default(PENDING)
  paymentId String?

  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TicketStatus {
  PENDING
  CONFIRMED
  SCANNED
  CANCELLED
}

// ─── Liste d'attente ───────────────────────────────────────────
model WaitlistEntry {
  id      String @id @default(cuid())
  userId  String
  eventId String

  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, eventId])
}

// ─── Musique ───────────────────────────────────────────────────
model MusicSuggestion {
  id        String  @id @default(cuid())
  title     String
  artist    String
  genre     String?
  link      String
  platform  MusicPlatform
  approved  Boolean @default(false)
  eventId   String
  userId    String

  event     Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes     Vote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MusicPlatform {
  YOUTUBE
  SPOTIFY
  SOUNDCLOUD
  OTHER
}

// ─── Vote ──────────────────────────────────────────────────────
model Vote {
  id                String @id @default(cuid())
  userId            String
  musicSuggestionId String

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  musicSuggestion   MusicSuggestion @relation(fields: [musicSuggestionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, musicSuggestionId])
}
